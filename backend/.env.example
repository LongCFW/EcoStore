PORT=5000
# MongoDB - Giữ nguyên nếu dùng Docker
MONGO_URI=mongodb://mongo:27017/ecostore

# JWT
JWT_SECRET=change_this_to_a_random_secret_key
JWT_EXPIRES_IN=7d

# EMAIL CONFIGURATION
# Hướng dẫn lấy Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# PAYOS CONFIG
# Đăng ký tại: https://payos.vn
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Domain frontend (dùng để PayOS redirect sau thanh toán)
YOUR_DOMAIN=http://localhost:5173

# Email admin quản lý cửa hàng
ADMIN_EMAIL=your_admin_email@gmail.com